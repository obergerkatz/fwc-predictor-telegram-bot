{
  "name": "football-predictor-bot",
  "version": "1.0.0",
  "description": "Football match prediction bot with Telegram integration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "migrate": "node dist/db/migrate.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "telegram",
    "bot",
    "football",
    "betting",
    "predictions"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "1.6.7",
    "dotenv": "17.3.1",
    "node-cron": "4.2.1",
    "pg": "8.20.0",
    "telegraf": "4.16.3",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.11",
    "@types/node": "25.5.0",
    "@types/node-cron": "3.0.11",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "6.19.0",
    "@typescript-eslint/parser": "6.19.0",
    "eslint": "8.56.0",
    "jest": "29.7.0",
    "nodemon": "3.0.3",
    "prettier": "3.2.4",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
